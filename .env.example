HOST=0.0.0.0
PORT=8787
PUBLIC_BASE_URL=https://your-public-domain.example.com
APPROVAL_SIGNING_SECRET=replace-with-a-long-random-string
ADMIN_ACCESS_TOKEN=replace-with-a-private-admin-password

# Safety defaults: keep both true/false as shown until you are ready.
DRY_RUN=true
AUTO_EXECUTION_ENABLED=false

# Telegram ingress
TELEGRAM_SOURCE_MODE=bot
TELEGRAM_BOT_TOKEN=123456:replace-me
# TELEGRAM_MODE only applies when TELEGRAM_SOURCE_MODE=bot
TELEGRAM_MODE=webhook
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_USER_SESSION=
TELEGRAM_USER_SESSION_FILE=./data/telegram-user-session.txt
TELEGRAM_ALLOWED_CHAT_IDS=-1001111111111,-1002222222222
TELEGRAM_ANALYST_CHAT_IDS=-1001111111111
TELEGRAM_NEWS_CHAT_IDS=-1002222222222
TELEGRAM_WEBHOOK_SECRET=replace-with-a-random-secret
TELEGRAM_POLL_TIMEOUT_SEC=20
TELEGRAM_CONNECTION_RETRIES=5

# Feishu notifications
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/replace-me
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# Discord notifications
DISCORD_WEBHOOK_URL=

# Gate spot trading
GATE_API_KEY=replace-me
GATE_API_SECRET=replace-me
GATE_BASE_URL=https://api.gateio.ws

# Runtime files
PLAYBOOKS_FILE=./config/playbooks.example.json
DATA_DIR=./data
MAX_DAILY_TRADES=5
MAX_DAILY_NOTIONAL_USD=1000
DEDUP_WINDOW_SEC=1800
MEDIA_RETENTION_DAYS=7
